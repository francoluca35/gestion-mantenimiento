# ─── Demo robusta (PC Windows 24/7 + Cloudflare Tunnel) ───
# cp .env.demo.example .env.demo
# powershell -File scripts/demo-up.ps1

NODE_ENV=production
API_PORT=3000
WEB_PORT=8080

# URL pública (Cloudflare Tunnel → api container)
PUBLIC_BASE_URL=https://api.sorjuanaliberte.store
CORS_ORIGINS=https://api.sorjuanaliberte.store,http://localhost:8080,http://localhost:3000

# ─── PostgreSQL (solo red interna Docker) ───
POSTGRES_USER=sika
POSTGRES_PASSWORD=CAMBIAR_password_fuerte_demo
POSTGRES_DB=gestion_mantenimiento

# ─── JWT (mínimo 32 caracteres, distintos) ───
JWT_SECRET=CAMBIAR_jwt_secret_largo_minimo_32_chars!!
JWT_REFRESH_SECRET=CAMBIAR_refresh_secret_largo_minimo_32!!
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (local = fotos por la API / mismo HTTPS) ───
STORAGE_PROVIDER=local
STORAGE_BUCKET=sika-mantenimiento

# ─── Backups ───
BACKUP_KEEP_DAYS=14
BACKUP_HOUR_UTC=5

# ─── Cloudflare Tunnel ───
# Tu conector está instalado como servicio automático de Windows:
#   Public hostname: api.sorjuanaliberte.store
#   Service: http://localhost:3000
# Dejar vacío. Solo usar token si se decide mover cloudflared a Docker.
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Firebase FCM (opcional) ───
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# ─── Crons ───
OT_CRON_ENABLED=true
STOCK_ALERT_CRON_ENABLED=true
SEED_ON_START=false

# En demo, mostrar código de recuperación de clave en la respuesta
PASSWORD_RESET_DEMO=true

# ─── Flutter / Android ───
# Perfil → Servidor API = https://api.sorjuanaliberte.store/v1
# LAN fallback = http://<IP-PC>:3000/v1
