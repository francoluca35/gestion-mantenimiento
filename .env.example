# ─── App ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
API_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ─── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=sika
POSTGRES_PASSWORD=sika_dev
POSTGRES_DB=gestion_mantenimiento
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sika:sika_dev@localhost:5432/gestion_mantenimiento?schema=public

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=cambiar_en_produccion_usar_string_largo
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=cambiar_refresh_en_produccion
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (dev = MinIO, prod = R2/S3) ───────────────
# provider: minio | r2 | s3 | local
STORAGE_PROVIDER=minio
STORAGE_BUCKET=sika-mantenimiento
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PUBLIC_URL=http://localhost:9000/sika-mantenimiento
STORAGE_FORCE_PATH_STYLE=true

# Producción Cloudflare R2 (ejemplo):
# STORAGE_PROVIDER=r2
# STORAGE_BUCKET=sika-mantenimiento
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=<r2_access_key>
# STORAGE_SECRET_KEY=<r2_secret_key>
# STORAGE_PUBLIC_URL=https://cdn.tudominio.com
# STORAGE_FORCE_PATH_STYLE=true

# Producción AWS S3 (ejemplo):
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=sika-mantenimiento
# STORAGE_REGION=sa-east-1
# STORAGE_ENDPOINT=
# STORAGE_ACCESS_KEY=<aws_key>
# STORAGE_SECRET_KEY=<aws_secret>
# STORAGE_PUBLIC_URL=https://sika-mantenimiento.s3.sa-east-1.amazonaws.com
# STORAGE_FORCE_PATH_STYLE=false

# ─── MinIO (solo docker-compose) ───────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Firebase FCM (push) ───────────────────────────────
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# ─── Flutter ───────────────────────────────────────────
# En apps/client/.env o --dart-define
# API_BASE_URL=http://10.0.2.2:3000/v1   # emulador Android
# API_BASE_URL=http://localhost:3000/v1  # web / desktop
# Demo pública: https://api.sorjuanaliberte.store/v1
# Ver .env.demo.example + docs/faltantes/sprint-5-infra-demo.md
