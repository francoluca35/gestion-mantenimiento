generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "postgresql"
	url      = env("DATABASE_URL")
}

enum SupervisaSolicitudesOt {
	ninguna
	de_su_sector
	todas
}

enum TipoMantenimiento {
	preventivo
	preventivo_no_periodico
	predictivo
	correctivo
	mejora
}

enum CriterioProgramacion {
	fecha_inicio
	fecha_finalizacion
}

enum EstadoOt {
	necesaria_de_emitir
	pendiente
	pendiente_panol
	en_ejecucion
	realizada
	anulada
}

enum PrioridadOt {
	baja
	media
	alta
	urgente
}

enum PeriodicidadTipo {
	tiempo
	contador
}

enum TipoAlcanceProcedimiento {
	ubicacion
	planta
}

enum EstadoProcedimientoEquipo {
	activo
	suspendido
	baja
}

enum EstadoSolicitudTrabajo {
	pendiente
	conformada
	rechazada
}

enum TipoMovimientoStock {
	entrada
	salida
	reserva
	devolucion
	transferencia
}

enum EstadoSolicitudMaterial {
	pendiente
	aprobado
	rechazado
}

enum EstadoPedidoStock {
	pendiente
	en_proceso
	completado
}

enum DecisionMaterialesOt {
	pendiente
	no_necesita
	necesita
}

enum EstadoOrdenCompra {
	solicitada
	autorizada
	no_autorizada
	anulada
	recibida
}

model Sucursal {
	id        String   @id @default(uuid()) @db.Uuid
	nombre    String   @db.VarChar(100)
	codigo    String   @unique @db.VarChar(20)
	activa    Boolean  @default(true)
	logoKey   String?  @map("logo_key") @db.VarChar(500)
	logoUrl   String?  @map("logo_url") @db.VarChar(800)
	createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

	usuarios             Usuario[]
	ubicaciones          Ubicacion[]
	equipos              Equipo[]
	procedimientos       Procedimiento[]
	procedimientoAlcances ProcedimientoAlcance[]
	ordenesTrabajo       OrdenTrabajo[]
	solicitudesTrabajo   SolicitudTrabajo[]
	equipoDocumentos     EquipoDocumento[]
	motivosOtPendiente   MotivoOtPendiente[]
	panoles              Panol[]
	proveedores          Proveedor[]
	ordenesCompra        OrdenCompra[]

	@@map("sucursales")
}

model MotivoOtPendiente {
	id          String   @id @default(uuid()) @db.Uuid
	sucursalId  String   @map("sucursal_id") @db.Uuid
	codigo      String   @db.VarChar(30)
	descripcion String   @db.VarChar(200)
	activo      Boolean  @default(true)
	orden       Int      @default(0)
	createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal       Sucursal       @relation(fields: [sucursalId], references: [id])
	ordenesTrabajo OrdenTrabajo[]

	@@unique([sucursalId, codigo])
	@@index([sucursalId, activo])
	@@map("motivos_ot_pendiente")
}

model Perfil {
	id          String   @id @default(uuid()) @db.Uuid
	nombre      String   @db.VarChar(100)
	descripcion String?  @db.Text
	activo      Boolean  @default(true)
	createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

	usuarios Usuario[]
	derechos PerfilDerecho[]

	@@map("perfiles")
}

model Derecho {
	id       String  @id @default(uuid()) @db.Uuid
	parentId String? @map("parent_id") @db.Uuid
	codigo   String  @unique @db.VarChar(100)
	nombre   String  @db.VarChar(200)
	orden    Int     @default(0)

	parent   Derecho?        @relation("DerechoTree", fields: [parentId], references: [id])
	children Derecho[]       @relation("DerechoTree")
	perfiles PerfilDerecho[]

	@@map("derechos")
}

model PerfilDerecho {
	perfilId   String  @map("perfil_id") @db.Uuid
	derechoId  String  @map("derecho_id") @db.Uuid
	habilitado Boolean @default(true)
	modoTotal  Boolean @default(false) @map("modo_total")

	perfil  Perfil  @relation(fields: [perfilId], references: [id], onDelete: Cascade)
	derecho Derecho @relation(fields: [derechoId], references: [id], onDelete: Cascade)

	@@id([perfilId, derechoId])
	@@map("perfil_derechos")
}

model Usuario {
	id                     String                 @id @default(uuid()) @db.Uuid
	nombreUsuario          String                 @unique @map("nombre_usuario") @db.VarChar(50)
	claveHash              String                 @map("clave_hash") @db.VarChar(255)
	email                  String?                @db.VarChar(100)
	sucursalId             String?                @map("sucursal_id") @db.Uuid
	sectorId               String?                @map("sector_id") @db.Uuid
	perfilId               String?                @map("perfil_id") @db.Uuid
	esAdministrador        Boolean                @default(false) @map("es_administrador")
	supervisaSucursales    Boolean                @default(false) @map("supervisa_sucursales")
	supervisaSolicitudesOt SupervisaSolicitudesOt @default(ninguna) @map("supervisa_solicitudes_ot")
	supervisaSolicitudesOc Boolean                @default(false) @map("supervisa_solicitudes_oc")
	montoMaximoOc          Decimal?               @map("monto_maximo_oc") @db.Decimal(15, 2)
	activo                 Boolean                @default(true)
	createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal Sucursal?  @relation(fields: [sucursalId], references: [id])
	perfil   Perfil?    @relation(fields: [perfilId], references: [id])
	sesiones              Sesion[]
	passwordResetTokens  PasswordResetToken[]
	dispositivosFcm      DispositivoFcm[]
	lecturas              Lectura[]
	ordenesAsignadas      OrdenTrabajo[]      @relation("OtTecnico")
	ordenesCreadas        OrdenTrabajo[]      @relation("OtCreador")
	historialOt           OtEstadoHistorial[]
	historialEquipo       HistorialEquipo[]
	documentosEquipo      EquipoDocumento[]
	movimientosStock      MovimientoStock[]
	solicitudesMaterial   SolicitudMaterial[] @relation("SolicitudMaterialSolicitante")
	solicitudesMaterialResueltas SolicitudMaterial[] @relation("SolicitudMaterialPanolero")
	pedidosStock          PedidoStock[]
	ordenesCompraCreadas  OrdenCompra[] @relation("OcCreador")
	ordenesCompraAutorizadas OrdenCompra[] @relation("OcAutorizador")

	@@map("usuarios")
}

model DispositivoFcm {
	id        String   @id @default(uuid()) @db.Uuid
	token     String   @unique @map("token") @db.VarChar(500)
	usuarioId String   @map("usuario_id") @db.Uuid
	createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

	usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

	@@index([usuarioId])
	@@map("dispositivos_fcm")
}

model Sesion {
	id               String   @id @default(uuid()) @db.Uuid
	usuarioId        String   @map("usuario_id") @db.Uuid
	refreshTokenHash String   @map("refresh_token_hash") @db.VarChar(255)
	expiresAt        DateTime @map("expires_at") @db.Timestamptz(6)
	revocada         Boolean  @default(false)
	createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

	usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

	@@index([usuarioId])
	@@map("sesiones")
}

model PasswordResetToken {
	id         String   @id @default(uuid()) @db.Uuid
	usuarioId  String   @map("usuario_id") @db.Uuid
	codigoHash String   @map("codigo_hash") @db.VarChar(255)
	expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
	usado      Boolean  @default(false)
	createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

	usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

	@@index([usuarioId, usado])
	@@map("password_reset_tokens")
}

model Ubicacion {
	id         String   @id @default(uuid()) @db.Uuid
	sucursalId String   @map("sucursal_id") @db.Uuid
	parentId   String?  @map("parent_id") @db.Uuid
	nombre     String   @db.VarChar(200)
	orden      Int      @default(0)
	activa     Boolean  @default(true)
	createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal Sucursal   @relation(fields: [sucursalId], references: [id])
	parent   Ubicacion? @relation("UbicacionTree", fields: [parentId], references: [id])
	children Ubicacion[] @relation("UbicacionTree")
	equipos              Equipo[]
	ordenesTrabajo       OrdenTrabajo[]
	procedimientosSector Procedimiento[] @relation("ProcedimientoSector")
	procedimientoAlcances ProcedimientoAlcance[]

	@@index([sucursalId, parentId])
	@@map("ubicaciones")
}

model TipoEquipo {
	id             String   @id @default(uuid()) @db.Uuid
	nombre         String   @db.VarChar(100)
	camposDetalle  Json     @default("[]") @map("campos_detalle")
	camposLectura  Json     @default("[]") @map("campos_lectura")
	activo         Boolean  @default(true)
	createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

	equipos Equipo[]

	@@map("tipos_equipo")
}

model Equipo {
	id               String    @id @default(uuid()) @db.Uuid
	sucursalId       String    @map("sucursal_id") @db.Uuid
	ubicacionId      String    @map("ubicacion_id") @db.Uuid
	tipoEquipoId     String    @map("tipo_equipo_id") @db.Uuid
	nombre           String    @db.VarChar(200)
	codigo           String    @db.VarChar(50)
	detalle          Json      @default("{}")
	fueraDeServicio  Boolean   @default(false) @map("fuera_de_servicio")
	fechaBaja        DateTime? @map("fecha_baja") @db.Date
	activo           Boolean   @default(true)
	createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal   Sucursal    @relation(fields: [sucursalId], references: [id])
	ubicacion  Ubicacion   @relation(fields: [ubicacionId], references: [id])
	tipoEquipo TipoEquipo  @relation(fields: [tipoEquipoId], references: [id])
	componentes           Componente[]
	lecturas              Lectura[]
	documentos            EquipoDocumento[]
	procedimientosEquipo  ProcedimientoEquipo[]
	ordenesTrabajo        OrdenTrabajo[]
	historial             HistorialEquipo[]

	@@unique([sucursalId, codigo])
	@@index([ubicacionId])
	@@index([sucursalId, activo])
	@@map("equipos")
}

model Componente {
	id       String  @id @default(uuid()) @db.Uuid
	equipoId String  @map("equipo_id") @db.Uuid
	nombre   String  @db.VarChar(200)
	codigo   String? @db.VarChar(50)
	detalle  Json?
	activo   Boolean @default(true)

	equipo Equipo @relation(fields: [equipoId], references: [id], onDelete: Cascade)

	@@index([equipoId])
	@@map("componentes")
}

model Lectura {
	id        String   @id @default(uuid()) @db.Uuid
	equipoId  String   @map("equipo_id") @db.Uuid
	usuarioId String?  @map("usuario_id") @db.Uuid
	otId      String?  @map("ot_id") @db.Uuid
	tipo      String   @db.VarChar(50)
	valor     Decimal  @db.Decimal(15, 2)
	fecha     DateTime @default(now()) @db.Timestamptz(6)
	notas     String?  @db.Text

	equipo  Equipo        @relation(fields: [equipoId], references: [id], onDelete: Cascade)
	usuario Usuario?      @relation(fields: [usuarioId], references: [id])
	ot      OrdenTrabajo? @relation(fields: [otId], references: [id])

	@@index([equipoId, fecha])
	@@map("lecturas")
}

model EquipoDocumento {
	id          String   @id @default(uuid()) @db.Uuid
	equipoId    String   @map("equipo_id") @db.Uuid
	sucursalId  String   @map("sucursal_id") @db.Uuid
	nombre      String   @db.VarChar(200)
	tipo        String   @default("otro") @db.VarChar(30)
	storageKey  String   @map("storage_key") @db.VarChar(500)
	contentType String?  @map("content_type") @db.VarChar(100)
	tamano      Int?
	activo      Boolean  @default(true)
	createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	creadorId   String?  @map("creador_id") @db.Uuid

	equipo   Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
	sucursal Sucursal @relation(fields: [sucursalId], references: [id])
	creador  Usuario? @relation(fields: [creadorId], references: [id])

	@@index([equipoId])
	@@map("equipo_documentos")
}

model Procedimiento {
	id                       String                 @id @default(uuid()) @db.Uuid
	codigo                   Int                    @unique @default(autoincrement())
	sucursalId               String                 @map("sucursal_id") @db.Uuid
	sectorResponsableId      String?                @map("sector_responsable_id") @db.Uuid
	nombre                   String                 @db.VarChar(200)
	tipo                     TipoMantenimiento
	descripcion              String?                @db.Text
	planillaLecturas         Json                   @default("[]") @map("planilla_lecturas")
	observaciones            String?                @db.Text
	periodicidadTipo         PeriodicidadTipo?      @map("periodicidad_tipo")
	periodicidadValor        Int?                   @map("periodicidad_valor")
	criterioProgramacion     CriterioProgramacion?  @map("criterio_programacion")
	tolerancia               Int                    @default(0)
	duracionEstimada         Int?                   @map("duracion_estimada")
	hsHombre                 Decimal?               @map("hs_hombre") @db.Decimal(8, 2)
	cantOperarios            Int?                   @map("cant_operarios")
	indisponibilidadEstimada Int?                   @map("indisponibilidad_estimada")
	costoEstimado            Decimal?               @map("costo_estimado") @db.Decimal(15, 2)
	versionActual            Int                    @default(1) @map("version_actual")
	activo                   Boolean                @default(true)
	createdAt                DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt                DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal          Sucursal              @relation(fields: [sucursalId], references: [id])
	sectorResponsable Ubicacion?            @relation("ProcedimientoSector", fields: [sectorResponsableId], references: [id])
	equipos           ProcedimientoEquipo[]
	alcances          ProcedimientoAlcance[]
	ordenes           OrdenTrabajo[]
	versiones         ProcedimientoVersion[]

	@@index([sucursalId, activo])
	@@map("procedimientos")
}

model ProcedimientoVersion {
	id              String   @id @default(uuid()) @db.Uuid
	procedimientoId String   @map("procedimiento_id") @db.Uuid
	version         Int
	snapshot        Json
	createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	createdById     String?  @map("created_by_id") @db.Uuid

	procedimiento Procedimiento @relation(fields: [procedimientoId], references: [id], onDelete: Cascade)

	@@unique([procedimientoId, version])
	@@index([procedimientoId, createdAt])
	@@map("procedimiento_versiones")
}

model ProcedimientoEquipo {
	id               String                    @id @default(uuid()) @db.Uuid
	procedimientoId  String                    @map("procedimiento_id") @db.Uuid
	equipoId         String                    @map("equipo_id") @db.Uuid
	estado           EstadoProcedimientoEquipo @default(activo)
	fechaAsociacion  DateTime                  @default(now()) @map("fecha_asociacion") @db.Date
	ultimaEmision    DateTime?                 @map("ultima_emision") @db.Date

	procedimiento Procedimiento @relation(fields: [procedimientoId], references: [id], onDelete: Cascade)
	equipo        Equipo        @relation(fields: [equipoId], references: [id], onDelete: Cascade)

	@@unique([procedimientoId, equipoId])
	@@map("procedimiento_equipos")
}

model ProcedimientoAlcance {
	id                String                    @id @default(uuid()) @db.Uuid
	procedimientoId   String                    @map("procedimiento_id") @db.Uuid
	tipo              TipoAlcanceProcedimiento
	ubicacionId       String?                   @map("ubicacion_id") @db.Uuid
	sucursalAlcanceId String?                   @map("sucursal_alcance_id") @db.Uuid
	estado            EstadoProcedimientoEquipo @default(activo)
	fechaAsociacion   DateTime                  @default(now()) @map("fecha_asociacion") @db.Date
	ultimaEmision     DateTime?                 @map("ultima_emision") @db.Date

	procedimiento   Procedimiento @relation(fields: [procedimientoId], references: [id], onDelete: Cascade)
	ubicacion       Ubicacion?    @relation(fields: [ubicacionId], references: [id])
	sucursalAlcance Sucursal?     @relation(fields: [sucursalAlcanceId], references: [id])

	@@unique([procedimientoId, ubicacionId])
	@@unique([procedimientoId, sucursalAlcanceId])
	@@map("procedimiento_alcances")
}

model OrdenTrabajo {
	id                        String            @id @default(uuid()) @db.Uuid
	numero                    Int               @unique @default(autoincrement())
	sucursalId                String            @map("sucursal_id") @db.Uuid
	ubicacionId               String            @map("ubicacion_id") @db.Uuid
	equipoId                  String            @map("equipo_id") @db.Uuid
	procedimientoId           String?           @map("procedimiento_id") @db.Uuid
	tipo                      TipoMantenimiento
	estado                    EstadoOt          @default(pendiente)
	tecnicoAsignadoId         String?           @map("tecnico_asignado_id") @db.Uuid
	creadorId                 String?           @map("creador_id") @db.Uuid
	fechaProgramacion         DateTime          @map("fecha_programacion") @db.Date
	fechaEjecucion            DateTime?         @map("fecha_ejecucion") @db.Date
	tolerancia                Int               @default(0)
	prioridad                 PrioridadOt       @default(media)
	motivoPendienteId         String?           @map("motivo_pendiente_id") @db.Uuid
	comentarios               String?           @db.Text
	novedadesFueraDePrograma  String?           @map("novedades_fuera_de_programa") @db.Text
	checklistCompletado       Json              @default("[]") @map("checklist_completado")
	firmaDigital              String?           @map("firma_digital") @db.Text
	fotos                     Json              @default("[]")
	otOrigenId                String?           @map("ot_origen_id") @db.Uuid
	lecturaRegistradaAt       DateTime?         @map("lectura_registrada_at") @db.Timestamptz(6)
	decisionMateriales        DecisionMaterialesOt @default(pendiente) @map("decision_materiales")
	materialesTextoLibre      String?           @map("materiales_texto_libre") @db.Text
	createdAt                 DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt                 DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal          Sucursal              @relation(fields: [sucursalId], references: [id])
	ubicacion         Ubicacion             @relation(fields: [ubicacionId], references: [id])
	equipo            Equipo                @relation(fields: [equipoId], references: [id])
	procedimiento     Procedimiento?        @relation(fields: [procedimientoId], references: [id])
	tecnicoAsignado   Usuario?              @relation("OtTecnico", fields: [tecnicoAsignadoId], references: [id])
	creador           Usuario?              @relation("OtCreador", fields: [creadorId], references: [id])
	motivoPendiente   MotivoOtPendiente?    @relation(fields: [motivoPendienteId], references: [id])
	otOrigen          OrdenTrabajo?         @relation("OtDerivadas", fields: [otOrigenId], references: [id])
	otsDerivadas      OrdenTrabajo[]        @relation("OtDerivadas")
	historialEstados  OtEstadoHistorial[]
	lecturas          Lectura[]
	solicitudOrigen   SolicitudTrabajo?     @relation("SolicitudOtGenerada")
	historialEquipo   HistorialEquipo[]
	solicitudesMaterial SolicitudMaterial[]
	movimientosStock  MovimientoStock[]
	pedidosStock      PedidoStock[]

	@@index([sucursalId, estado])
	@@index([tecnicoAsignadoId, estado])
	@@index([equipoId])
	@@index([otOrigenId])
	@@map("ordenes_trabajo")
}

model OtEstadoHistorial {
	id         String   @id @default(uuid()) @db.Uuid
	otId       String   @map("ot_id") @db.Uuid
	estado     EstadoOt
	usuarioId  String?  @map("usuario_id") @db.Uuid
	comentario String?  @db.Text
	createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

	ot      OrdenTrabajo @relation(fields: [otId], references: [id], onDelete: Cascade)
	usuario Usuario?     @relation(fields: [usuarioId], references: [id])

	@@index([otId, createdAt])
	@@map("ot_estado_historial")
}

model SolicitudTrabajo {
	id            String                 @id @default(uuid()) @db.Uuid
	sucursalId    String                 @map("sucursal_id") @db.Uuid
	solicitante   String                 @db.VarChar(200)
	descripcion   String                 @db.Text
	urgente       Boolean                @default(false)
	estado        EstadoSolicitudTrabajo @default(pendiente)
	calificacion  String?                @db.VarChar(20)
	observaciones String?                @db.Text
	otGeneradaId  String?                @unique @map("ot_generada_id") @db.Uuid
	createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt     DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal   Sucursal      @relation(fields: [sucursalId], references: [id])
	otGenerada OrdenTrabajo? @relation("SolicitudOtGenerada", fields: [otGeneradaId], references: [id])

	@@index([sucursalId, estado])
	@@map("solicitudes_trabajo")
}

model HistorialEquipo {
	id          String   @id @default(uuid()) @db.Uuid
	equipoId    String   @map("equipo_id") @db.Uuid
	otId        String?  @map("ot_id") @db.Uuid
	tipoEvento  String   @map("tipo_evento") @db.VarChar(50)
	descripcion String   @db.Text
	fecha       DateTime @default(now()) @db.Timestamptz(6)
	usuarioId   String?  @map("usuario_id") @db.Uuid

	equipo  Equipo        @relation(fields: [equipoId], references: [id], onDelete: Cascade)
	ot      OrdenTrabajo? @relation(fields: [otId], references: [id])
	usuario Usuario?      @relation(fields: [usuarioId], references: [id])

	@@index([equipoId, fecha])
	@@map("historial_equipo")
}

model Unidad {
	id     String  @id @default(uuid()) @db.Uuid
	codigo String  @unique @db.VarChar(20)
	nombre String  @db.VarChar(50)
	activo Boolean @default(true)

	materiales Material[]

	@@map("unidades")
}

model Panol {
	id         String   @id @default(uuid()) @db.Uuid
	sucursalId String   @map("sucursal_id") @db.Uuid
	nombre     String   @db.VarChar(100)
	activo     Boolean  @default(true)
	createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal    Sucursal           @relation(fields: [sucursalId], references: [id])
	stockItems  StockItem[]
	movimientos MovimientoStock[]
	solicitudes SolicitudMaterial[]
	pedidos     PedidoStock[]

	@@index([sucursalId, activo])
	@@map("panoles")
}

model Material {
	id           String   @id @default(uuid()) @db.Uuid
	codigo       String   @unique @db.VarChar(50)
	nombre       String   @db.VarChar(200)
	marca        String?  @db.VarChar(100)
	uso          String   @default("Mantenimiento") @db.VarChar(50)
	unidadId     String   @map("unidad_id") @db.Uuid
	precioActual Decimal  @default(0) @map("precio_actual") @db.Decimal(15, 2)
	activo       Boolean  @default(true)
	createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

	unidad      Unidad             @relation(fields: [unidadId], references: [id])
	stockItems  StockItem[]
	movimientos MovimientoStock[]
	solicitudes SolicitudMaterial[]
	pedidos     PedidoStock[]
	ordenesCompraDetalle OrdenCompraDetalle[]

	@@index([activo, nombre])
	@@map("materiales")
}

model StockItem {
	id                 String  @id @default(uuid()) @db.Uuid
	panolId            String  @map("panol_id") @db.Uuid
	materialId         String  @map("material_id") @db.Uuid
	cantidadActual     Decimal @default(0) @map("cantidad_actual") @db.Decimal(10, 2)
	cantidadMinima     Decimal @default(0) @map("cantidad_minima") @db.Decimal(10, 2)
	cantidadReservada  Decimal @default(0) @map("cantidad_reservada") @db.Decimal(10, 2)

	panol    Panol    @relation(fields: [panolId], references: [id], onDelete: Cascade)
	material Material @relation(fields: [materialId], references: [id])

	@@unique([panolId, materialId])
	@@index([materialId])
	@@map("stock_items")
}

model MovimientoStock {
	id        String              @id @default(uuid()) @db.Uuid
	panolId   String              @map("panol_id") @db.Uuid
	materialId String             @map("material_id") @db.Uuid
	tipo      TipoMovimientoStock
	cantidad  Decimal             @db.Decimal(10, 2)
	otId      String?             @map("ot_id") @db.Uuid
	usuarioId String?             @map("usuario_id") @db.Uuid
	fecha     DateTime            @default(now()) @db.Timestamptz(6)
	origen    String?             @db.VarChar(50)
	notas     String?             @db.Text

	panol    Panol         @relation(fields: [panolId], references: [id])
	material Material      @relation(fields: [materialId], references: [id])
	ot       OrdenTrabajo? @relation(fields: [otId], references: [id])
	usuario  Usuario?      @relation(fields: [usuarioId], references: [id])

	@@index([panolId, fecha])
	@@index([materialId, fecha])
	@@index([otId])
	@@map("movimientos_stock")
}

model SolicitudMaterial {
	id                  String                  @id @default(uuid()) @db.Uuid
	otId                String                  @map("ot_id") @db.Uuid
	panolId             String                  @map("panol_id") @db.Uuid
	materialId          String                  @map("material_id") @db.Uuid
	cantidadSolicitada  Decimal                 @map("cantidad_solicitada") @db.Decimal(10, 2)
	estado              EstadoSolicitudMaterial @default(pendiente)
	solicitanteId       String?                 @map("solicitante_id") @db.Uuid
	panoleroId          String?                 @map("panolero_id") @db.Uuid
	fechaSolicitud      DateTime                @default(now()) @map("fecha_solicitud") @db.Timestamptz(6)
	fechaResolucion     DateTime?               @map("fecha_resolucion") @db.Timestamptz(6)
	motivoRechazo       String?                 @map("motivo_rechazo") @db.Text

	ot          OrdenTrabajo @relation(fields: [otId], references: [id], onDelete: Cascade)
	panol       Panol        @relation(fields: [panolId], references: [id])
	material    Material     @relation(fields: [materialId], references: [id])
	solicitante Usuario?     @relation("SolicitudMaterialSolicitante", fields: [solicitanteId], references: [id])
	panolero    Usuario?     @relation("SolicitudMaterialPanolero", fields: [panoleroId], references: [id])

	@@index([otId, estado])
	@@index([panolId, estado])
	@@index([estado, fechaSolicitud])
	@@map("solicitudes_material")
}

model PedidoStock {
	id         String           @id @default(uuid()) @db.Uuid
	numero     Int              @unique @default(autoincrement())
	panolId    String           @map("panol_id") @db.Uuid
	materialId String           @map("material_id") @db.Uuid
	otId       String?          @map("ot_id") @db.Uuid
	cantidad   Decimal          @db.Decimal(10, 2)
	estado     EstadoPedidoStock @default(pendiente)
	usuarioId  String?          @map("usuario_id") @db.Uuid
	notas      String?          @db.Text
	createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
	completadoAt DateTime?      @map("completado_at") @db.Timestamptz(6)

	panol    Panol         @relation(fields: [panolId], references: [id])
	material Material      @relation(fields: [materialId], references: [id])
	usuario  Usuario?      @relation(fields: [usuarioId], references: [id])
	ot       OrdenTrabajo? @relation(fields: [otId], references: [id])

	@@index([panolId, estado])
	@@index([estado, createdAt])
	@@index([otId])
	@@map("pedidos_stock")
}

model Proveedor {
	id           String   @id @default(uuid()) @db.Uuid
	sucursalId   String   @map("sucursal_id") @db.Uuid
	nombre       String   @db.VarChar(200)
	cuit         String?  @db.VarChar(20)
	contacto     String?  @db.VarChar(200)
	telefono     String?  @db.VarChar(50)
	email        String?  @db.VarChar(100)
	calificacion Decimal? @db.Decimal(3, 1)
	activo       Boolean  @default(true)
	createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal      Sucursal      @relation(fields: [sucursalId], references: [id])
	ordenesCompra OrdenCompra[]

	@@index([sucursalId, activo])
	@@index([sucursalId, nombre])
	@@map("proveedores")
}

model OrdenCompra {
	id                 String           @id @default(uuid()) @db.Uuid
	numero             Int
	sucursalId         String           @map("sucursal_id") @db.Uuid
	proveedorId        String           @map("proveedor_id") @db.Uuid
	estado             EstadoOrdenCompra @default(solicitada)
	montoTotal         Decimal          @default(0) @map("monto_total") @db.Decimal(15, 2)
	creadoPorId        String?          @map("creado_por_id") @db.Uuid
	autorizadoPorId    String?          @map("autorizado_por_id") @db.Uuid
	fechaSolicitud     DateTime         @default(now()) @map("fecha_solicitud") @db.Timestamptz(6)
	fechaAutorizacion  DateTime?        @map("fecha_autorizacion") @db.Timestamptz(6)
	notas              String?          @db.Text
	createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
	updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

	sucursal      Sucursal             @relation(fields: [sucursalId], references: [id])
	proveedor     Proveedor            @relation(fields: [proveedorId], references: [id])
	creadoPor     Usuario?             @relation("OcCreador", fields: [creadoPorId], references: [id])
	autorizadoPor Usuario?             @relation("OcAutorizador", fields: [autorizadoPorId], references: [id])
	detalles      OrdenCompraDetalle[]

	@@unique([sucursalId, numero])
	@@index([sucursalId, estado])
	@@index([proveedorId])
	@@map("ordenes_compra")
}

model OrdenCompraDetalle {
	id             String  @id @default(uuid()) @db.Uuid
	ordenCompraId  String  @map("orden_compra_id") @db.Uuid
	materialId     String  @map("material_id") @db.Uuid
	cantidad       Decimal @db.Decimal(10, 2)
	precioUnitario Decimal @map("precio_unitario") @db.Decimal(15, 2)

	ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
	material    Material    @relation(fields: [materialId], references: [id])

	@@index([ordenCompraId])
	@@index([materialId])
	@@map("ordenes_compra_detalle")
}
